# Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore

# ── YouTube Data API v3 ──────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ── Google Gemini (for VVRA trend scoring + Vault hooks) ─────
# Get from: https://ai.google.dev/gemini-api
GEMINI_API_KEY=your_gemini_api_key

# ── Cloudinary (video transformation + CDN delivery) ─────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── AWS Region ───────────────────────────────────────────────
# Must be us-east-1 (Amazon Nova is only in us-east-1)
REGION=us-east-1

# ── DynamoDB Table Names (auto-set by CDK deploy) ────────────
# These are injected by backend-stack.ts at deploy time.
# Set manually only if deploying without CDK.
JOBS_TABLE=your_jobs_table_name

# ── MediaConvert ─────────────────────────────────────────────
# Role ARN for MediaConvert (created during CDK deploy)
MEDIACONVERT_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/MediaConvertRole

# ── CORS Allowlist (Function URL) ────────────────────────────
# Comma-separated origins allowed to call the Cloudinary Analyze Lambda
ALLOWED_ORIGINS=https://main.d16fcylhtesdpm.amplifyapp.com,http://localhost:5173
